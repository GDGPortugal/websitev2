---
interface Event {
  _id: string;
  title: string;
  date: string;
  description: string;
  time: string;
  location: string;
  city: string;
  mode: string;
  image?: {
    asset: {
      _ref: string;
    };
  };
}

const events: Event[] = [];
---

<div class="container mx-auto px-4 py-10 md:px-8 lg:px-16">
  <h1 class="mb-4 text-center text-4xl font-bold text-black">Próximos eventos</h1>
  <p class="mt-2 mb-8 text-center text-2xl text-[#6C6C6C]">
    Comunidades do país inteiro se conectando em um único lugar!
  </p>

  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
    {
      events.map((event) => (
        <div
          class="relative flex h-[500px] flex-col overflow-hidden rounded-3xl p-8 text-white"
          style="background: linear-gradient(to bottom right, #111111, #1c1c1e, #004d40);"
        >
          <div class="flex-1">
            <span class="text-sm text-blue-200">
              {new Date(event.date).toLocaleDateString('pt-PT')}
            </span>

            <h2 class="mb-2 text-2xl font-bold">{event.title}</h2>

            {event.description && (
              <p class="line-clamp-4 leading-relaxed text-blue-100">
                {typeof event.description === 'string' ? event.description : 'Descrição disponível'}
              </p>
            )}

            <div class="mt-4 space-y-1 text-sm">
              {event.time && (
                <p>
                  <strong>🕒</strong> {event.time}
                </p>
              )}
              {event.location && (
                <p>
                  <strong>📍</strong> {event.location}
                  {event.city ? `, ${event.city}` : ''}
                </p>
              )}
            </div>

            {event.mode && (
              <div class="mt-3">
                <span class="rounded-full bg-blue-600 px-3 py-1 text-xs text-white">
                  {event.mode}
                </span>
              </div>
            )}
          </div>

          {event.image && (
            <div class="mt-6">
              <div class="rounded-2xl bg-white p-2 shadow-lg">
                <img
                  src={event.image.asset._ref}
                  alt={event.title}
                  class="h-32 w-full rounded-lg object-cover"
                />
              </div>
            </div>
          )}
        </div>
      ))
    }
  </div>
</div>
